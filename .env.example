# RabbitMQ — broker que entrega eventos para o consumer (notification.queue)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# SMTP — canal de e-mail (confirmação, lembrete, recibo, redefinição de senha)
# Para Gmail: gere uma "Senha de app" em
# Conta Google → Segurança → Verificação em duas etapas → Senhas de app
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Evolution API — canal de WhatsApp (lembretes/confirmações via WPP)
# Em dev com docker-compose, base-url normalmente é http://evolution-api:8080
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=default
